# GEMINI_API_KEY: Required for Gemini AI API calls (primary AI provider)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DEEPSEEK_API_KEY: Required for DeepSeek AI API calls (fallback AI provider)
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# GROQ_API_KEY: Required for Groq AI API calls (second fallback AI provider)
GROQ_API_KEY="MY_GROQ_API_KEY"

# SUPABASE_URL: The URL of your Supabase project (e.g., https://xyz.supabase.co)
SUPABASE_URL=""

# SUPABASE_SERVICE_ROLE_KEY: The secret service role key for secure backend database transactions
SUPABASE_SERVICE_ROLE_KEY=""

# APP_URL: The URL where this applet is hosted (auto-injected by Cloudflare)
APP_URL="MY_APP_URL"
